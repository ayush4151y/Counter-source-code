<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/date_sublabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/total_today"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />

                    <TextView
                        android:id="@+id/total_usage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/coolvetica_rg"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="55sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <neth.iecal.curbox.ui.views.WeeklyBarGraphView
                android:id="@+id/weekly_bar_graph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_prev_week"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/baseline_arrow_back_ios_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tv_week_range"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                <ImageButton
                    android:id="@+id/btn_next_week"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/baseline_arrow_forward_ios_24"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/website_usage_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:nestedScrollingEnabled="false" />

            <Space
                android:layout_width="1dp"
                android:layout_height="300dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <neth.iecal.curbox.ui.views.FlowerBloomLoadingView
            android:layout_width="160dp"
            android:layout_height="80dp" />
    </LinearLayout>
</FrameLayout>
