<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/infoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="@string/picker_control_tap_to_select"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <Button
            android:id="@+id/deeperBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/btn_deeper"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/shallowerBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/btn_parent"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/blockBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/btn_block"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/blockAllBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/btn_all"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/moveBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/btn_move"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="2dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:text="@string/close"
            android:textAllCaps="false"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
